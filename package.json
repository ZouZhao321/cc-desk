{
	"name": "cc-desk",
	"private": true,
	"version": "0.1.0",
	"type": "module",
	"scripts": {
		"dev": "vite",
		"build": "vue-tsc --noEmit && vite build",
		"preview": "vite preview",
		"tauri": "tauri dev",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:rs": "cd src-tauri && cargo test",
		"lint": "eslint src/",
		"lint:fix": "eslint src/ --fix",
		"lint:rs": "cd src-tauri && cargo clippy -- -D warnings",
		"format": "prettier --write \"src/**/*.{ts,vue,css,json}\"",
		"format:check": "prettier --check \"src/**/*.{ts,vue,css,json}\"",
		"format:rs": "cd src-tauri && cargo fmt",
		"format:rs:check": "cd src-tauri && cargo fmt --check",
		"lint-staged": "lint-staged",
		"prepare": "husky"
	},
	"lint-staged": {
		"src/**/*.{ts,vue}": [
			"eslint --fix",
			"prettier --write",
			"vitest run"
		],
		"*.{css,json,md}": [
			"prettier --write"
		]
	},
	"dependencies": {
		"@tauri-apps/api": "^2",
		"@tauri-apps/plugin-store": "^2.4.3",
		"naive-ui": "^2.44.1",
		"vue": "^3.5.13"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@tauri-apps/cli": "^2",
		"@vitejs/plugin-vue": "^5.2.1",
		"@vue/test-utils": "^2.4.11",
		"eslint": "^9.39.4",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-vue": "^10.9.2",
		"happy-dom": "^20.10.3",
		"husky": "^9.1.7",
		"lint-staged": "^17.0.7",
		"prettier": "^3.8.3",
		"typescript": "~5.6.2",
		"typescript-eslint": "8.60.0",
		"unocss": "^66.7.0",
		"vite": "^6.0.3",
		"vitest": "^4.1.8",
		"vue-tsc": "^2.1.10"
	}
}
